class Solution {
public:
    int countCollisions(string directions) {
        int n = directions.length();
        int left = 0, right = n - 1;

        // 1. Remove cars moving left at the start (they never collide)
        while (left < n && directions[left] == 'L') {
            left++;
        }

        // 2. Remove cars moving right at the end (they never collide)
        while (right >= 0 && directions[right] == 'R') {
            right--;
        }

        int collisions = 0;
        // 3. Every moving car ('L' or 'R') left in the middle will eventually collide
        for (int i = left; i <= right; ++i) {
            if (directions[i] != 'S') {
                collisions++;
            }
        }

        return collisions;
    }
};
