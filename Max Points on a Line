import java.util.*;

class Solution {
    public int maxPoints(int[][] points) {
        int n = points.length;
        if (n <= 2) return n;
        
        int maxPoints = 1;
        
        for (int i = 0; i < n; i++) {
            // Map stores slope as a string "dy/dx" to avoid precision issues
            Map<String, Integer> map = new HashMap<>();
            int localMax = 0;
            
            for (int j = i + 1; j < n; j++) {
                int dx = points[j][0] - points[i][0];
                int dy = points[j][1] - points[i][1];
                
                // Simplify the slope by dividing by the Greatest Common Divisor
                int gcd = gcd(dx, dy);
                String slope = (dy / gcd) + "/" + (dx / gcd);
                
                map.put(slope, map.getOrDefault(slope, 0) + 1);
                localMax = Math.max(localMax, map.get(slope));
            }
            // +1 to include the starting point i itself
            maxPoints = Math.max(maxPoints, localMax + 1);
        }
        
        return maxPoints;
    }
    
    private int gcd(int a, int b) {
        return b == 0 ? a : gcd(b, a % b);
    }
}
