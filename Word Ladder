import java.util.*;

class Solution {
    public int ladderLength(String beginWord, String endWord, List<String> wordList) {
        Set<String> dict = new HashSet<>(wordList);
        // If the target word isn't in the dictionary, no path exists
        if (!dict.contains(endWord)) return 0;

        Queue<String> queue = new LinkedList<>();
        queue.offer(beginWord);
        
        // 'level' represents the number of words in the current sequence
        int level = 1;

        while (!queue.isEmpty()) {
            int size = queue.size();
            
            // Process all words at the current distance level
            for (int i = 0; i < size; i++) {
                String curr = queue.poll();
                
                // If we reached the endWord, return the current length
                if (curr.equals(endWord)) return level;
                
                // Find all possible neighbors
                char[] chars = curr.toCharArray();
                for (int j = 0; j < chars.length; j++) {
                    char oldChar = chars[j];
                    
                    for (char c = 'a'; c <= 'z'; c++) {
                        if (c == oldChar) continue;
                        chars[j] = c;
                        String next = new String(chars);
                        
                        if (dict.contains(next)) {
                            queue.offer(next);
                            // Remove from dictionary so we don't visit it again
                            dict.remove(next);
                        }
                    }
                    // Restore character for the next position's check
                    chars[j] = oldChar;
                }
            }
            level++;
        }

        return 0;
    }
}
