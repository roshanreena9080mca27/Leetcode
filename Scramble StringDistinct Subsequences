class Solution {
    public int numDistinct(String s, String t) {
        int m = s.length();
        int n = t.length();
        
        // dp[j] will store the number of subsequences of t[0...j-1]
        int[] dp = new int[n + 1];
        
        // Base case: an empty string t is a subsequence of any prefix of s
        // So, dp[0] is always 1.
        dp[0] = 1;
        
        for (int i = 1; i <= m; i++) {
            // We iterate backwards to ensure we use values from the "previous row"
            // (the previous i-1 state) without overwriting them prematurely.
            for (int j = n; j >= 1; j--) {
                if (s.charAt(i - 1) == t.charAt(j - 1)) {
                    // Current total = (ways without this char) + (ways using this char)
                    dp[j] = dp[j] + dp[j - 1];
                }
                // If they don't match, dp[j] remains dp[j] (from the previous row)
            }
        }
        
        return dp[n];
    }
}
