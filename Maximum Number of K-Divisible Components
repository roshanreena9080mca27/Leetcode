class Solution {
public:
    int maxComponents = 0;

    long long dfs(int u, int p, const vector<vector<int>>& adj, const vector<int>& values, int k) {
        long long current_sum = values[u];
        
        for (int v : adj[u]) {
            if (v != p) {
                // Add the sum of the child subtree (mod k is enough to prevent overflow)
                current_sum += dfs(v, u, adj, values, k);
            }
        }
        
        // If the current subtree sum is divisible by k, it can be a separate component
        if (current_sum % k == 0) {
            maxComponents++;
            return 0; // Return 0 because this component is "cut off"
        }
        
        return current_sum % k;
    }

    int maxKDivisibleComponents(int n, vector<vector<int>>& edges, vector<int>& values, int k) {
        vector<vector<int>> adj(n);
        for (auto& edge : edges) {
            adj[edge[0]].push_back(edge[1]);
            adj[edge[1]].push_back(edge[0]);
        }

        maxComponents = 0;
        dfs(0, -1, adj, values, k);
        
        return maxComponents;
    }
};
