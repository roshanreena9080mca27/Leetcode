class TimeLimitedCache {
    constructor() {
        this.cache = new Map(); // Stores { key: [value, timeoutRef] }
    }

    /** 
     * @param {number} key
     * @param {number} value
     * @param {number} duration time until expiration in ms
     * @return {boolean} if un-expired key already existed
     */
    set(key, value, duration) {
        const exists = this.cache.has(key);

        // If it already exists, cancel the old expiration timer
        if (exists) {
            clearTimeout(this.cache.get(key)[1]);
        }

        // Set a new timer to delete the key after 'duration'
        const timeoutRef = setTimeout(() => {
            this.cache.delete(key);
        }, duration);

        this.cache.set(key, [value, timeoutRef]);
        return exists;
    }

    /** 
     * @param {number} key
     * @return {number} value associated with key
     */
    get(key) {
        return this.cache.has(key) ? this.cache.get(key)[0] : -1;
    }

    /** 
     * @return {number} count of non-expired keys
     */
    count() {
        return this.cache.size;
    }
}
