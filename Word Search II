import java.util.*;

class Solution {
    class TrieNode {
        Map<Character, TrieNode> children = new HashMap<>();
        String word = null; // Stores the full word at the leaf node
    }

    public List<String> findWords(char[][] board, String[] words) {
        // 1. Build the Trie
        TrieNode root = new TrieNode();
        for (String w : words) {
            TrieNode curr = root;
            for (char c : w.toCharArray()) {
                curr.children.putIfAbsent(c, new TrieNode());
                curr = curr.children.get(c);
            }
            curr.word = w;
        }

        List<String> result = new ArrayList<>();
        int m = board.length, n = board[0].length;

        // 2. Start DFS from every cell
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                if (root.children.containsKey(board[i][j])) {
                    dfs(board, i, j, root, result);
                }
            }
        }
        return result;
    }

    private void dfs(char[][] board, int i, int j, TrieNode node, List<String> result) {
        char c = board[i][j];
        TrieNode currNode = node.children.get(c);

        // Check if we found a word
        if (currNode.word != null) {
            result.add(currNode.word);
            currNode.word = null; // Avoid duplicate entries
        }

        // Mark current cell as visited
        board[i][j] = '#';

        // Explore neighbors: Up, Down, Left, Right
        int[] rowOffset = {-1, 1, 0, 0};
        int[] colOffset = {0, 0, -1, 1};

        for (int k = 0; k < 4; k++) {
            int newI = i + rowOffset[k];
            int newJ = j + colOffset[k];

            if (newI >= 0 && newI < board.length && newJ >= 0 && newJ < board[0].length 
                && board[newI][newJ] != '#' && currNode.children.containsKey(board[newI][newJ])) {
                dfs(board, newI, newJ, currNode, result);
            }
        }

        // Backtrack: Restore the cell
        board[i][j] = c;

        // Optimization: Prune the Trie leaf nodes
        if (currNode.children.isEmpty()) {
            node.children.remove(c);
        }
    }
}
