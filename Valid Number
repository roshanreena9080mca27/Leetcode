class Solution {
    public boolean isNumber(String s) {
        boolean seenDigit = false;
        boolean seenDot = false;
        boolean seenE = false;

        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);

            if (Character.isDigit(c)) {
                seenDigit = true;
            } 
            else if (c == '+' || c == '-') {
                // Signs are only valid at the start or immediately after 'e'/'E'
                if (i > 0 && s.charAt(i - 1) != 'e' && s.charAt(i - 1) != 'E') {
                    return false;
                }
            } 
            else if (c == 'e' || c == 'E') {
                // 'e' must follow a digit and only appear once
                if (seenE || !seenDigit) {
                    return false;
                }
                seenE = true;
                // Reset seenDigit because an integer must follow the exponent
                seenDigit = false;
            } 
            else if (c == '.') {
                // Dot only allowed once and NOT after 'e'
                if (seenDot || seenE) {
                    return false;
                }
                seenDot = true;
            } 
            else {
                // Invalid characters
                return false;
            }
        }

        // Must have seen at least one digit (and one after 'e' if 'e' exists)
        return seenDigit;
    }
}
