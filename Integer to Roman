#include <string>
#include <vector>

using namespace std;

class Solution {
public:
    string intToRoman(int num) {
        // List values and symbols in descending order, including subtractive cases
        vector<pair<int, string>> romanMapping = {
            {1000, "M"}, {900, "CM"}, {500, "D"}, {400, "CD"},
            {100, "C"}, {90, "XC"}, {50, "L"}, {40, "XL"},
            {10, "X"}, {9, "IX"}, {5, "V"}, {4, "IV"}, {1, "I"}
        };

        string result = "";
        
        for (auto const& [value, symbol] : romanMapping) {
            // While the current value can be subtracted from num
            while (num >= value) {
                result += symbol;
                num -= value;
            }
        }
        
        return result;
    }
};
