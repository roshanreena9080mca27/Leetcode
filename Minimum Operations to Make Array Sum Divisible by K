class Solution {
public:
    int minOperations(vector<int>& nums, int k) {
        long long total_sum = 0;
        for (int num : nums) {
            total_sum += num;
        }
        
        // The remainder is the number of operations needed 
        // to reach the nearest multiple of k below total_sum.
        return total_sum % k;
    }
};
